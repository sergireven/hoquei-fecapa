{
  "buildCommand": "npm install",
  "outputDirectory": "public",
  "functions": {
    "api/server.js": {
      "memory": 512,
      "maxDuration": 300
    },
    "api/cron.js": {
      "maxDuration": 300
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/server.js" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ],
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "0 10 * * 1-5"
    },
    {
      "path": "/api/cron",
      "schedule": "0 8 * * 0,6"
    },
    {
      "path": "/api/cron",
      "schedule": "0 11 * * 0,6"
    },
    {
      "path": "/api/cron",
      "schedule": "0 14 * * 0,6"
    },
    {
      "path": "/api/cron",
      "schedule": "0 17 * * 0,6"
    },
    {
      "path": "/api/cron",
      "schedule": "0 20 * * 0,6"
    }
  ]
}
